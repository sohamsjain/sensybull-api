SECRET_KEY=your-secret-key
DATABASE_URL=sqlite:///sensybull_api.db
JWT_SECRET_KEY=your-jwt-secret-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
EDGAR_IDENTITY=Soham Jain sohamsjain@gmail.com

# ---------------------------------------------------------------------------
# Application identity - used in transactional email subjects, links, footer
# ---------------------------------------------------------------------------
APP_NAME=Sensybull
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@example.com

# ---------------------------------------------------------------------------
# Email delivery
# MAIL_PROVIDER: console (dev, logs to stdout) | resend | smtp
# ---------------------------------------------------------------------------
MAIL_PROVIDER=console
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Sensybull
MAIL_REPLY_TO=support@example.com

# Resend
RESEND_API_KEY=

# SMTP (Google Workspace / Zoho / M365 / SES / MailHog)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true

# Token lifetimes (hours)
EMAIL_VERIFY_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=1

# Rate limiter storage (memory:// for dev; redis://... for prod)
RATELIMIT_STORAGE_URI=memory://
