# ── Shared ────────────────────────────────────────────────────────────────
# Redis pub/sub bus the publisher writes filing:new events to.
REDIS_URL=redis://localhost:6379/0

# ── services/ingest ───────────────────────────────────────────────────────
SEC_USER_AGENT=Your Name your@email.com
# Comma-separated list of Groq API keys for round-robin rotation.
# Falls back to GROQ_API_KEY (singular) if not set.
GROQ_API_KEYS=
GROQ_API_KEY=
