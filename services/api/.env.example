# ── Shared ────────────────────────────────────────────────────────────────
# Redis pub/sub bus the subscriber listens on for filing:new events.
REDIS_URL=redis://localhost:6379/0

# ── Core ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key
# SQLite (dev):  sqlite:///sensybull_api.db
# Postgres:      postgresql://sensybull:sensybull@localhost:5432/sensybull
DATABASE_URL=postgresql://sensybull:sensybull@localhost:5432/sensybull
JWT_SECRET_KEY=your-jwt-secret-key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SEC user-agent (required by SEC EDGAR fair-access policy).
SEC_USER_AGENT=Your Name your@email.com

# ── Application identity ──────────────────────────────────────────────────
APP_NAME=Sensybull
FRONTEND_URL=http://localhost:3000
# Comma-separated CORS origins (defaults to FRONTEND_URL if not set)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.sensybull.com
SUPPORT_EMAIL=support@example.com

# ── Email delivery (console | resend | smtp) ──────────────────────────────
MAIL_PROVIDER=console
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Sensybull
MAIL_REPLY_TO=support@example.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true

# ── Token lifetimes (hours) ───────────────────────────────────────────────
EMAIL_VERIFY_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=1

# ── Rate limiter storage (memory:// for dev; redis://... for prod) ─────────
# In production, use Redis so rate limits are shared across API instances:
# RATELIMIT_STORAGE_URI=redis://redis:6379/0
RATELIMIT_STORAGE_URI=memory://

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT=json   # set to "json" for structured JSON logs in production

# ── Error monitoring (Sentry) ─────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production
