# ── Shared ────────────────────────────────────────────────────────────────
# Redis pub/sub bus the subscriber listens on for filing:new events.
REDIS_URL=redis://localhost:6379/0

# ── Core ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key
DATABASE_URL=sqlite:///sensybull_api.db
JWT_SECRET_KEY=your-jwt-secret-key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SEC EDGAR identity used by the company-loader / streaming scripts.
EDGAR_IDENTITY=Your Name your@email.com

# ── Application identity ──────────────────────────────────────────────────
APP_NAME=Sensybull
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@example.com

# ── Email delivery (console | resend | smtp) ──────────────────────────────
MAIL_PROVIDER=console
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Sensybull
MAIL_REPLY_TO=support@example.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true

# ── Token lifetimes (hours) ───────────────────────────────────────────────
EMAIL_VERIFY_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=1

# ── Rate limiter storage (memory:// for dev; redis://... for prod) ─────────
RATELIMIT_STORAGE_URI=memory://
